<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product Id="*"
           Name="RigAlert"
           Language="1033"
           Version="2.1.0.0"
           Manufacturer="ING Mining"
           UpgradeCode="{BCFD1762-F821-40F1-88B7-55583E9C0084}">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Description="RigAlert by ING Mining — Bitcoin Miner Monitor"
             Comments="Professional ASIC Fleet Monitor" />

    <!-- Upgrade handling: remove old version before installing new -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of RigAlert is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- App icon shown in Add/Remove Programs -->
    <Icon Id="RigAlertIcon" SourceFile="..\rigalert.ico" />
    <Property Id="ARPPRODUCTICON"  Value="RigAlertIcon" />
    <Property Id="ARPHELPLINK"     Value="https://github.com/essquireo0o/rigalert" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/essquireo0o/rigalert" />
    <Property Id="ARPNOREPAIR"     Value="1" />

    <!-- ── Directory structure ───────────────────────────────────── -->
    <Directory Id="TARGETDIR" Name="SourceDir">

      <!-- C:\Program Files\ING Mining\RigAlert -->
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INGMININGDIR" Name="ING Mining">
          <Directory Id="INSTALLDIR" Name="RigAlert" />
        </Directory>
      </Directory>

      <!-- Start Menu\RigAlert -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="STARTMENUFOLDER" Name="RigAlert" />
      </Directory>

      <!-- Desktop -->
      <Directory Id="DesktopFolder" />

    </Directory>

    <!-- ── Components ────────────────────────────────────────────── -->

    <!-- Main EXE -->
    <DirectoryRef Id="INSTALLDIR">
      <Component Id="MainExecutable" Guid="{47F51454-0286-4986-A0CD-551C804F01A4}" Win64="yes">
        <File Id="RigAlertEXE"
              Source="..\dist\RigAlert.exe"
              KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Start Menu shortcut -->
    <DirectoryRef Id="STARTMENUFOLDER">
      <Component Id="StartMenuShortcut" Guid="{72B347AA-C2BA-450B-9906-BA203E645292}">
        <Shortcut Id="StartMenuLink"
                  Name="RigAlert"
                  Description="RigAlert by ING Mining — Bitcoin Miner Monitor"
                  Target="[INSTALLDIR]RigAlert.exe"
                  WorkingDirectory="INSTALLDIR"
                  Icon="RigAlertIcon"
                  IconIndex="0" />
        <RemoveFolder Id="RemoveStartMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\ING Mining\RigAlert"
                       Name="StartMenuInstalled"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Desktop shortcut -->
    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="{99EC1FB6-5889-46A5-A8E7-C7E69F3B419C}">
        <Shortcut Id="DesktopLink"
                  Name="RigAlert"
                  Description="RigAlert by ING Mining — Bitcoin Miner Monitor"
                  Target="[INSTALLDIR]RigAlert.exe"
                  WorkingDirectory="INSTALLDIR"
                  Icon="RigAlertIcon"
                  IconIndex="0" />
        <RegistryValue Root="HKCU"
                       Key="Software\ING Mining\RigAlert"
                       Name="DesktopInstalled"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Windows startup — HKCU Run key (per-user, added for installing account) -->
    <DirectoryRef Id="INSTALLDIR">
      <Component Id="StartupRegistryKey" Guid="{5DF14AE8-DCF9-4156-BFA2-FF3301A71C2B}">
        <RegistryValue Root="HKCU"
                       Key="Software\Microsoft\Windows\CurrentVersion\Run"
                       Name="RigAlert"
                       Type="string"
                       Value="[INSTALLDIR]RigAlert.exe"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- ── Features ──────────────────────────────────────────────── -->

    <!-- Core application — required, cannot be deselected -->
    <Feature Id="MainApp"
             Title="RigAlert"
             Description="Bitcoin ASIC fleet monitoring application by ING Mining."
             Level="1"
             Absent="disallow"
             Display="expand">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <!-- Optional startup — checked by default (Level=1), user can uncheck -->
    <Feature Id="StartupFeature"
             Title="Launch RigAlert on Windows startup"
             Description="Automatically start RigAlert when Windows starts. You can change this later in Task Manager &gt; Startup."
             Level="1">
      <ComponentRef Id="StartupRegistryKey" />
    </Feature>

    <!-- ── UI ────────────────────────────────────────────────────── -->
    <UIRef Id="WixUI_FeatureTree" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

  </Product>
</Wix>
